{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "types": [
            "node"
        ], // 🔥 VERY IMPORTANT
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
    }
}